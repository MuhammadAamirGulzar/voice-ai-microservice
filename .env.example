# ============================================
# Voice Microservice - Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Server Settings
# ============================================
HOST=127.0.0.1
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# Service Identity
SERVICE_NAME=voice-microservice
SERVICE_VERSION=3.0.0

# ============================================
# AI Layer Configuration (External Microservice)
# ============================================
# The AI Layer handles conversation logic and response generation.
# Set USE_LOCAL_LLM=true to bypass AI Layer and use local LLM for testing.

AI_LAYER_BASE_URL=http://localhost:8001
AI_LAYER_CHAT_ENDPOINT=/api/v1/chat
AI_LAYER_TIMEOUT_SECONDS=30
AI_LAYER_RETRY_ATTEMPTS=3
AI_LAYER_API_KEY=
# Tighter budget for live voice turns (a caller won't wait out 30s + retries)
AI_LAYER_VOICE_TIMEOUT_SECONDS=10

# ============================================
# Production hardening
# ============================================
# When set, every /api/* request must send this in the X-API-Key header.
# Leave empty only on trusted-network deployments.
VOICE_API_KEY=
# Comma-separated allowed browser origins ("*" disables credentials)
CORS_ORIGINS=*
# Per-IP sliding-window rate limit on /api/* (uses RATE_LIMIT_REQUESTS_PER_MINUTE)
RATE_LIMIT_ENABLED=false
# Sessions created via /start but never connected are reaped after this
MAX_PENDING_SESSION_MINUTES=10
SESSION_CLEANUP_INTERVAL_SECONDS=60

# ============================================
# Local LLM Fallback (for testing without AI Layer)
# ============================================
# Set USE_LOCAL_LLM=true to use OpenAI/Groq directly instead of AI Layer
USE_LOCAL_LLM=false

# Provider: "openai" or "groq"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=300

# ============================================
# API Keys
# ============================================
# AssemblyAI (STT - Speech-to-Text)
ASSEMBLYAI_API_KEY=your_api_key_here

# Google Cloud TTS (Text-to-Speech)
GOOGLE_CLOUD_TTS_CREDENTIALS=google-credentials.json

# OpenAI (required if USE_LOCAL_LLM=true and LLM_PROVIDER=openai)
OPENAI_API_KEY=your_api_key_here

# Groq (optional, for faster LLM responses)
GROQ_API_KEY=your_api_key_here

# ============================================
# TTS Configuration (Google Cloud)
# ============================================
# Available Chirp 3 HD voices (required for streaming):
# - Zephyr (Female), Puck (Male), Charon (Male), Kore (Female)
# - Aoede (Female), Fenrir (Male), Leda (Female), Orus (Male)
TTS_VOICE_NAME=en-US-Chirp3-HD-Zephyr
TTS_LANGUAGE_CODE=en-US
TTS_SPEAKING_RATE=1.0
TTS_PITCH=0.0

# ============================================
# STT Configuration (AssemblyAI)
# ============================================
STT_LANGUAGE=en_us
STT_SAMPLE_RATE=16000

# ============================================
# Session Settings
# ============================================
# Default session mode: interactive, stt_only, tts_only
DEFAULT_SESSION_MODE=interactive

# Maximum session duration
MAX_SESSION_DURATION_MINUTES=60

# Session timeout (inactive sessions are cleaned up)
SESSION_TIMEOUT_MINUTES=30

# Maximum sessions per organization
MAX_SESSIONS_PER_ORG=100

# ============================================
# Transcript Storage
# ============================================
TRANSCRIPT_DIR=logs/transcripts

# ============================================
# WebRTC Settings (Optional)
# ============================================
# Public IP for WebRTC ICE candidates (set on production servers)
PUBLIC_IP=
